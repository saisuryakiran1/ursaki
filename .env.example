# =============================================================================
# UrSaKi Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# --- Backend (FastAPI) ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:1420,http://localhost:8081

# --- LLM / AI Engine ---
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gemma2:2b
DESKTOP_MODEL=llama3:8b
# Cloud fallback — video generation ONLY; requires explicit opt-in
OPENAI_API_KEY=

# --- ChromaDB (vector store for emotional memory) ---
CHROMA_PERSIST_DIR=./backend/data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Safety ---
SAFETY_GUARD_TIMEOUT_MS=50
CRISIS_HOTLINE_ICALL=9152987821
CRISIS_HOTLINE_VANDREVALA=1860-2662-345

# --- Solid Protocol Data Pods ---
SOLID_IDENTITY_PROVIDER=
SOLID_POD_URL=

# --- WebRTC (desktop hybrid compute) ---
WEBRTC_SIGNALING_PORT=9000

# --- BLE Social Bridge ---
BLE_SERVICE_UUID=0000ursa-0000-1000-8000-00805f9b34fb
BRIDGE_TOKEN_ROTATION_MINUTES=30

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:8000

# --- Desktop (Tauri) ---
TAURI_DEV_HOST=localhost
TAURI_DEV_PORT=1420

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./backend/logs
