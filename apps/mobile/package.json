{
  "name": "@ursaki/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "App.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "dev": "expo start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 || true",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@ursaki/shared": "*",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@react-navigation/.*)"
    ],
    "testMatch": [
      "**/src/tests/**/*.test.tsx"
    ]
  }
}
